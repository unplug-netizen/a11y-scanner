# ============================================
# A11y Scanner - Environment Variables
# ============================================

# --------------------------------------------
# REQUIRED: OpenAI API
# --------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# --------------------------------------------
# REQUIRED: Supabase (Auth und Datenbank)
# --------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --------------------------------------------
# OPTIONAL: Sentry (Error Tracking)
# --------------------------------------------
SENTRY_DSN=https://your-sentry-dsn-here

# --------------------------------------------
# OPTIONAL: Redis (Caching)
# --------------------------------------------
# Option 1: Standard Redis URL
REDIS_URL=redis://localhost:6379
# Option 2: Upstash Redis (für Serverless)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# --------------------------------------------
# OPTIONAL: Browser Pool Configuration
# --------------------------------------------
BROWSER_POOL_MAX_PAGES=5
BROWSER_POOL_IDLE_TIMEOUT=300000

# --------------------------------------------
# OPTIONAL: Logging
# --------------------------------------------
LOG_LEVEL=info

# --------------------------------------------
# OPTIONAL: Cron Secret (für Scheduled Scans)
# --------------------------------------------
CRON_SECRET=your-cron-secret-here

# --------------------------------------------
# OPTIONAL: Email Notifications (Resend)
# --------------------------------------------
RESEND_API_KEY=re_your-resend-api-key

# --------------------------------------------
# OPTIONAL: Slack Integration
# --------------------------------------------
# Slack Bot Token für erweiterte Features
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
